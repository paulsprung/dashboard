# Port the Pi Agent listens on
PORT=3002

# Shared secret — must match PI_AGENT_SECRET in dashboard/.env
AGENT_SECRET=change_me_strong_secret

# Local subnet to scan for device discovery (CIDR notation)
# Usually your home network, e.g. 192.168.1.0/24
LOCAL_SUBNET=192.168.1.0/24

# Interface the Pi Agent listens on.
# 127.0.0.1 → only reachable via Tailscale tunnel (recommended).
# Set to your Tailscale IP (100.x.x.x) to bind directly to the Tailscale interface.
# 0.0.0.0 exposes the agent to the full LAN — only use if you have no other option.
BIND_HOST=127.0.0.1

# Where device configs (secrets) and the audit log are stored.
# Persisted via the Docker volume mount in compose.yml — back this up.
DATA_DIR=./data

# ── Just-in-Time remote access via Tailscale (OPTIONAL) ───────────────────────
# Leave these blank to keep the feature OFF. When all three are set, the Pi can
# open time-boxed Tailscale ACL grants so you can reach a device (e.g. Proxmox)
# on demand. See REMOTE_ACCESS.md. Requires data/acl-baseline.json to exist.
#
# Tailscale API access token with ACL write scope (Admin console → Settings → Keys,
# or an OAuth client with the `acl` scope). This key is powerful — keep it on the Pi only.
TS_API_KEY=
# Your tailnet name (Admin console → Settings → General), e.g. you@gmail.com or example.ts.net
TS_TAILNET=
# The Tailscale identity that grants are opened for (who may connect), e.g. you@gmail.com
TS_ADMIN_IDENTITY=
