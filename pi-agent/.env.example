# Port the Pi Agent listens on
PORT=3002

# Shared secret — must match PI_AGENT_SECRET in dashboard/.env
AGENT_SECRET=change_me_strong_secret

# Local subnet to scan for device discovery (CIDR notation)
# Usually your home network, e.g. 192.168.1.0/24
LOCAL_SUBNET=192.168.1.0/24

# Tailscale interface name (usually tailscale0)
# Used to bind only on Tailscale IP, not exposed to internet
# Leave empty to listen on all interfaces (0.0.0.0) — only do this in a trusted LAN
BIND_HOST=0.0.0.0

# Where device configs (secrets) and the audit log are stored.
# Persisted via the Docker volume mount in compose.yml — back this up.
DATA_DIR=./data
