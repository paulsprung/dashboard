# Tailscale IP or local IP of the Raspberry Pi running the Pi Agent
PI_AGENT_URL=http://100.x.x.x:3002

# Must match AGENT_SECRET in pi-agent/.env
AGENT_SECRET=change_me_strong_secret

# Optional: override auto-detected hostname
# HOSTNAME_OVERRIDE=my-server

# Heartbeat interval in seconds (default: 30)
HEARTBEAT_INTERVAL=30
