# App
PORT=3001
ORIGIN=https://dashboard.yourdomain.com
RP_ID=dashboard.yourdomain.com
RP_NAME=SM Dashboard
REQUIRE_USER_VERIFICATION=true
STRICT_PERSISTENCE=true

# PostgreSQL
POSTGRES_DB=sm_dashboard
POSTGRES_USER=sm_dashboard
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://sm_dashboard:change_me_strong_password@postgres:5432/sm_dashboard

# Pi Agent (optional — if set, device commands are forwarded to the Pi Agent)
# Use the Tailscale IP of your Raspberry Pi
# PI_AGENT_URL=http://100.x.x.x:3002
# PI_AGENT_SECRET=change_me_strong_secret
